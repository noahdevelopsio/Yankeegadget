# Database Configuration
# Replace with your PostgreSQL connection string (local, Supabase, Neon, or RDS)
DATABASE_URL="postgresql://postgres:password@localhost:5432/yankeegadgets?schema=public"

# Authentication Security (JWT signed session secret)
# Generate a secure secret using: openssl rand -base64 32
NEXTAUTH_SECRET="your_long_secure_custom_jwt_secret_phrase_here"

# Flutterwave Payment Gateway Credentials
# Find these in your Flutterwave Dashboard -> Settings -> API Keys
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxx-X"
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxx-X"

# Webhook Security hash
# Choose a custom phrase; must match the hash registered in Flutterwave Webhooks settings
FLW_SECRET_HASH="your_secure_custom_webhook_hash_here"

# Public site deployment URL (for payment redirection parameters)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
