# Database connection URL (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/yankee_gadgets?schema=public"

# NextAuth Config (Session & security keys)
NEXTAUTH_SECRET="some-very-long-and-secure-random-string-for-next-auth"
NEXTAUTH_URL="http://localhost:3000"

# Flutterwave Payment Gateway (Standard / Inline)
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X"
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X"
FLW_SECRET_HASH="your_flutterwave_secret_hash_for_webhooks"

# Cloudinary Image Hosting
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# Resend Email Integration
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
ADMIN_ALERT_EMAIL="admin@yankeegadgets.ng"

# General Web Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
